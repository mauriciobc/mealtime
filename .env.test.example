# Test environment (copy to .env.test.local)

# App under test (local dev server or staging URL)
PLAYWRIGHT_BASE_URL=http://localhost:3000

# Required for authenticated E2E (chromium project + auth.setup)
# Without these, authenticated specs are auto-skipped via tests/fixtures/test-fixtures.ts
TEST_USER_EMAIL=
TEST_USER_PASSWORD=

# Optional: pin a household for household-specific UI/API tests
TEST_HOUSEHOLD_ID=

# Optional: cron routes exercised in security E2E
CRON_SECRET=

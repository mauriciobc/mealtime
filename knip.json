    "components/onboarding-wrapper.tsx": ["exports"],
    "lib/services/apiService.ts": ["exports"],
    "lib/services/api-feeding-service.ts": ["exports"],
    "lib/data.ts": ["exports"],
    "lib/utils/feedingUtils.ts": ["exports"],
    "lib/selectors/statisticsSelectors.ts": ["exports", "types"],
    "lib/utils/date.ts": ["exports", "types"],
    "lib/context/WeightContext.tsx": ["exports"],
    "utils/supabase/storage.ts": ["exports"],
    "lib/repositories/cat-repository.ts": ["exports"],
    "lib/repositories/household-repository.ts": ["exports"],
    "lib/repositories/schedule-repository.ts": ["exports"],
    "lib/types.ts": ["types"],
    "lib/types/common.ts": ["types"],
    "lib/utils/api-error-handling.ts": ["types"],
    "lib/types/notification.ts": ["types"],
    "types/monitoring.ts": ["types"],

    "components/weight/current-status-card.tsx",
    "components/weight/recent-history-list.tsx",
  ],
  "ignoreDependencies": [
    "ts-node",
    "form-data",
    "swagger-ui-dist"
  ],
  "ignoreExportsUsedInFile": true,
  "ignoreIssues": {
    "utils/supabase/middleware.ts": ["exports"],

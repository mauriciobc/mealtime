    "lib/prisma/safe-access.ts",
    "lib/services/feeding-service.ts",
    "lib/services/notification-service.ts",
    "lib/services/statistics-service.ts",
    "lib/utils/EventSystem.ts",
    "lib/utils/Memoization.ts",
    "lib/utils/PerformanceMonitor.ts",
    "lib/utils/StateSelectors.ts",
    "lib/utils/StorageAnalytics.ts",
    "lib/utils/StorageService.ts",
    "lib/utils/api-utils.ts",
    "lib/utils/cache.ts",
